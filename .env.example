# ---------------------------------------------------------------------------
# Own Your Trade — example environment variables.
# Copy to ".env.local" and fill in real values. NEVER commit real secrets.
# The app runs in demo mode when these are absent.
# ---------------------------------------------------------------------------

# Stripe TEST-mode keys — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe LIVE-mode keys — PRODUCTION ONLY (set on Vercel, never in .env.local).
# When present, NEW signups check out in live mode (real money); test mode
# stays available locally/preview because these are absent there. Existing
# test-mode signups keep working — each signup records its own mode.
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_PUBLISHABLE_KEY=

# Owner dashboard login (demo password gates the sample dashboards).
DASHBOARD_PASSWORD=
DASHBOARD_SECRET=

# Private /admin area (real leads/signups) — keep distinct from the demo login.
ADMIN_PASSWORD=
ADMIN_SECRET=

# Resend transactional email — https://resend.com/api-keys
# Sends the signup confirmation + owner notification after a real Stripe
# payment. Never fires for demo/sample actions. Leave blank to disable email.
RESEND_API_KEY=
# Sender address. Use Resend's onboarding@resend.dev until a domain is verified,
# then e.g. "Own Your Trade <hello@yourdomain.com>".
EMAIL_FROM=
# Where new-signup notification emails are sent.
OWNER_NOTIFICATION_EMAIL=

# Stripe webhook signing secrets — sync subscription state (cancellations,
# failed payments) from Stripe. One endpoint serves both modes; each mode's
# registered webhook has its own secret.
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_LIVE=
