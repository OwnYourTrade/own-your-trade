# ---------------------------------------------------------------------------
# Own Your Trade — environment configuration
# Copy this file to ".env.local" and fill in the values you want.
# Everything here is OPTIONAL — the app runs fully in "demo mode" without it.
# ---------------------------------------------------------------------------

# Stripe TEST-mode keys (get them at https://dashboard.stripe.com/test/apikeys).
# Used by the takeaway ordering demo. When set, checkout uses real Stripe
# test-mode Checkout with test cards. When absent, checkout falls back to a
# clearly-labelled demo flow.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Owner dashboard / lead-tracker login (defaults shown — change for anything
# non-demo). One password gates every owner view (kitchen, booking diaries,
# lead tracker).
DASHBOARD_PASSWORD=owner
DASHBOARD_SECRET=change-me-to-a-long-random-string

# Resend transactional email (https://resend.com/api-keys). When set, a real
# "Get started" signup that completes Stripe payment triggers a customer
# confirmation email + an owner notification. Never fires for demo/sample
# actions. When absent, no emails are sent (the flow still works).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Sender. Resend's shared onboarding@resend.dev only delivers to your own Resend
# account email until you verify a domain; then use "You <hello@yourdomain>".
EMAIL_FROM=Own Your Trade <onboarding@resend.dev>
# Where new-signup notification emails are sent.
OWNER_NOTIFICATION_EMAIL=you@example.com

# Stripe webhook signing secret (https://dashboard.stripe.com/webhooks, or the
# `stripe listen` CLI output locally). Required for subscription state to sync
# (payment confirmations, cancellations, failed payments).
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
